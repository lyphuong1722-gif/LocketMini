<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – LocketMini</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
            :root {
                --locket-primary: #2563eb;
                --locket-primary-dark: #1d4ed8;
                --locket-primary-light: #60a5fa;
                --locket-accent: #38bdf8;
                --locket-bg: #f5f8fc;
                --locket-card: #ffffff;
                --locket-border: #e2e8f0;
                --locket-text: #0f172a;
                --locket-muted: #64748b;
            }

            body {
                background: var(--locket-bg);
                color: var(--locket-text);
                font-family: 'Segoe UI', system-ui, sans-serif;
            }

            /* Navbar */
            .navbar-locket {
                background: #fff;
                border-bottom: 1px solid var(--locket-border);
                box-shadow: 0 1px 3px rgba(15,23,42,.06);
            }

            .navbar-brand-locket {
                font-weight: 800;
                font-size: 1.35rem;
                background: linear-gradient(135deg, var(--locket-primary), var(--locket-accent));
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent !important;
                letter-spacing: -.5px;
            }

                .navbar-brand-locket span {
                    color: var(--locket-text);
                    -webkit-text-fill-color: var(--locket-text);
                }

            /* Alerts */
            .alert-toast {
                position: fixed;
                top: 1rem;
                right: 1rem;
                z-index: 9999;
                min-width: 280px;
                border-radius: .75rem;
                box-shadow: 0 4px 20px rgba(37,99,235,.15);
            }

            /* Cards */
            .card-post {
                border: 1px solid var(--locket-border);
                border-radius: 1rem;
                overflow: hidden;
                transition: box-shadow .2s, transform .2s;
            }

                .card-post:hover {
                    box-shadow: 0 8px 24px rgba(37,99,235,.12);
                    transform: translateY(-2px);
                }

            .post-image {
                width: 100%;
                max-height: 480px;
                object-fit: cover;
            }

            /* Buttons */
            .btn-orange {
                background: linear-gradient(135deg, var(--locket-primary), var(--locket-primary-dark));
                color: #fff;
                border: none;
                border-radius: .6rem;
                font-weight: 600;
                transition: filter .15s;
            }

                .btn-orange:hover {
                    filter: brightness(1.08);
                    color: #fff;
                }

            .btn-like {
                color: var(--locket-muted);
                border: none;
                background: none;
                font-size: .95rem;
                padding: .3rem .6rem;
            }

                .btn-like.liked {
                    color: #ef4444;
                }

                .btn-like:hover {
                    background: #eff6ff;
                    border-radius: .4rem;
                }

            /* Avatar placeholder */
            .avatar {
                width: 40px;
                height: 40px;
                background: linear-gradient(135deg, var(--locket-primary), var(--locket-accent));
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-weight: 700;
                font-size: .95rem;
                flex-shrink: 0;
            }

            .avatar-lg {
                width: 72px;
                height: 72px;
                font-size: 1.6rem;
            }

            /* Sidebar */
            .sidebar-sticky {
                position: sticky;
                top: 80px;
            }

            /* Forms */
            .form-control:focus {
                border-color: var(--locket-primary);
                box-shadow: 0 0 0 .2rem rgba(37,99,235,.2);
            }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-md navbar-locket sticky-top">
        <div class="container">
            <a class="navbar-brand navbar-brand-locket" asp-controller="Posts" asp-action="Index">
                <span class="brand-icon">📸</span><span class="brand-text">Locket</span><span class="brand-text-dark">Mini</span>
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Search bar -->
                    <form class="d-flex mx-auto" asp-controller="Users" asp-action="Search" method="get" style="max-width:320px; width:100%">
                        <div class="input-group">
                            <input class="form-control form-control-sm" type="search" name="keyword"
                                   placeholder="Tìm kiếm người dùng..." value="@Context.Request.Query["keyword"]" />
                            <button class="btn btn-sm btn-orange" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link fw-500" asp-controller="Posts" asp-action="Index">
                                <i class="bi bi-house-door"></i> Feed
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Friends" asp-action="Index">
                                <i class="bi bi-people"></i> Bạn bè
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-orange btn-sm px-3" asp-controller="Posts" asp-action="Create">
                                <i class="bi bi-plus-lg"></i> Đăng bài
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <span class="avatar" style="width:32px;height:32px;font-size:.8rem">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </span>
                                <span class="d-none d-md-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius:.75rem">
                                <li>
                                    <a class="dropdown-item" asp-controller="Users" asp-action="Me">
                                        <i class="bi bi-person me-2"></i>Trang cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword">
                                        <i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="dropdown-item text-danger" type="submit">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto gap-2">
                        <li class="nav-item">
                            <a class="btn btn-outline-secondary btn-sm" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-orange btn-sm" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <!-- Toast notifications -->
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-toast d-flex align-items-center gap-2" role="alert" id="toast-msg">
            <i class="bi bi-check-circle-fill"></i> @successMsg
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-toast d-flex align-items-center gap-2" role="alert" id="toast-msg">
            <i class="bi bi-exclamation-circle-fill"></i> @errorMsg
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <main class="py-4">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-dismiss toast sau 4 giây
        setTimeout(() => {
        const t = document.getElementById('toast-msg');
        if (t) { const a = bootstrap.Alert.getOrCreateInstance(t); a.close(); }
        }, 4000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
