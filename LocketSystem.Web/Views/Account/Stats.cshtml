@model LocketMini.Application.DTOs.PostStatsDto
@{
    ViewData["Title"] = "Thống kê bài viết"; Layout = "_Layout";
}

<div class="container" style="max-width:500px">
    <a asp-action="Detail" asp-route-id="@Model.PostId" class="btn btn-sm btn-light mb-3">
        <i class="bi bi-arrow-left me-1"></i>Quay lại bài viết
    </a>

    <div class="card border-0 shadow-sm" style="border-radius:1.25rem">
        <div class="card-body p-4">
            <h5 class="fw-700 mb-4"><i class="bi bi-bar-chart me-2"></i>Thống kê bài viết</h5>

            <div class="mb-3">
                <span class="text-muted small">Tác giả</span>
                <div class="fw-700">@Model.Username</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Caption))
            {
                <div class="mb-3">
                    <span class="text-muted small">Caption</span>
                    <div>@Model.Caption</div>
                </div>
            }

            <div class="row g-3 mt-1">
                <div class="col-6">
                    <div class="card bg-light border-0 text-center p-3" style="border-radius:.75rem">
                        <div class="fw-800 fs-2" style="color:#ef4444">@Model.LikeCount</div>
                        <div class="text-muted small"><i class="bi bi-heart-fill me-1"></i>Lượt thích</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card bg-light border-0 text-center p-3" style="border-radius:.75rem">
                        <div class="fw-800 fs-2" style="color:var(--locket-primary)">@Model.CommentCount</div>
                        <div class="text-muted small"><i class="bi bi-chat-fill me-1"></i>Bình luận</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
