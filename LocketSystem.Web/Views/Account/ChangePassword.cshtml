@model LocketMini.Web.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu"; Layout = "_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-10 col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm" style="border-radius:1.25rem">
            <div class="card-body p-4">
                <h5 class="fw-700 mb-1"><i class="bi bi-shield-lock me-2"></i>Đổi mật khẩu</h5>
                <p class="text-muted small mb-4">Chọn mật khẩu mạnh để bảo vệ tài khoản.</p>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-600 small"></label>
                        <input asp-for="CurrentPassword" class="form-control" placeholder="Mật khẩu hiện tại" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-600 small"></label>
                        <input asp-for="NewPassword" class="form-control" placeholder="Mật khẩu mới (≥ 6 ký tự)" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-600 small"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-orange fw-600 flex-grow-1">Lưu thay đổi</button>
                        <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
