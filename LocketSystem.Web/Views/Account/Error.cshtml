@model LocketSystem.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Lỗi"; Layout = "_Layout";
}

<div class="container text-center py-5" style="max-width:480px">
    <div style="font-size:4rem">😵</div>
    <h3 class="fw-700 mt-3">Đã xảy ra lỗi</h3>
    <p class="text-muted">Xin lỗi, có điều gì đó không ổn. Vui lòng thử lại.</p>
    @if (Model?.ShowRequestId == true)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Posts" asp-action="Index" class="btn btn-orange mt-2">
        <i class="bi bi-house me-1"></i>Về trang chủ
    </a>
</div>
