@model LocketMini.Web.Models.MutualFriendsViewModel
@{
    ViewData["Title"] = "Bạn chung"; Layout = "_Layout";
}

<div class="container" style="max-width:640px">
    <a asp-controller="Users" asp-action="Profile" asp-route-id="@Model.OtherUserId"
       class="btn btn-sm btn-light mb-3">
        <i class="bi bi-arrow-left me-1"></i>Quay lại trang cá nhân
    </a>

    <h5 class="fw-700 mb-4">
        <i class="bi bi-people me-2"></i>Bạn chung (@Model.Friends.Count)
    </h5>

    @if (!Model.Friends.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:2.5rem">🤝</div>
            <p class="mt-2">Không có bạn chung nào.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <ul class="list-group list-group-flush" style="border-radius:1rem">
                @foreach (var f in Model.Friends)
                {
                    <li class="list-group-item px-4 py-3">
                        <div class="d-flex align-items-center gap-3">
                            <span class="avatar">@f.Username.Substring(0, 1).ToUpper()</span>
                            <div class="flex-grow-1">
                                <a asp-controller="Users" asp-action="Profile" asp-route-id="@f.UserId"
                                   class="fw-700 text-dark text-decoration-none">@f.Username</a>
                                @if (!string.IsNullOrWhiteSpace(f.FullName))
                                {
                                    <div class="text-muted small">@f.FullName</div>
                                }
                            </div>
                            <a asp-controller="Users" asp-action="Profile" asp-route-id="@f.UserId"
                               class="btn btn-sm btn-outline-secondary">Xem trang</a>
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
</div>
