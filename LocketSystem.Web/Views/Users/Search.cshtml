@model LocketSystem.Web.Models.SearchUsersViewModel
@{
    ViewData["Title"] = "Tìm kiếm người dùng"; Layout = "_Layout";
}

<div class="container" style="max-width:680px">
    <h5 class="fw-700 mb-3"><i class="bi bi-search me-2"></i>Tìm kiếm người dùng</h5>

    <form asp-action="Search" method="get" class="mb-4">
        <div class="input-group">
            <input type="search" name="keyword" class="form-control"
                   placeholder="Nhập tên đăng nhập hoặc họ tên..."
                   value="@Model.Keyword" autofocus />
            <button class="btn btn-orange" type="submit">
                <i class="bi bi-search me-1"></i>Tìm
            </button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Keyword))
    {
        @if (!Model.Users.Any())
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:2.5rem">🔍</div>
                <p class="mt-2">Không tìm thấy người dùng nào khớp với "<strong>@Model.Keyword</strong>".</p>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">Kết quả cho "<strong>@Model.Keyword</strong>"</p>
            <div class="card border-0 shadow-sm" style="border-radius:1rem">
                <ul class="list-group list-group-flush" style="border-radius:1rem">
                    @foreach (var u in Model.Users)
                    {
                        <li class="list-group-item px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <span class="avatar">@u.Username.Substring(0, 1).ToUpper()</span>
                                <div class="flex-grow-1">
                                    <div class="fw-700">@u.Username</div>
                                    @if (!string.IsNullOrWhiteSpace(u.FullName))
                                    {
                                        <div class="text-muted small">@u.FullName</div>
                                    }
                                </div>
                                <a asp-controller="Users" asp-action="Profile" asp-route-id="@u.UserId"
                                   class="btn btn-sm btn-outline-secondary">
                                    Xem trang
                                </a>
                            </div>
                        </li>
                    }
                </ul>
            </div>

            @if (Model.HasPrev || Model.HasNext)
            {
                <div class="d-flex justify-content-center gap-2 mt-4">
                    @if (Model.HasPrev)
                    {
                        <a asp-action="Search" asp-route-keyword="@Model.Keyword"
                           asp-route-page="@(Model.Page - 1)"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-chevron-left"></i> Trước
                        </a>
                    }
                    <span class="btn btn-light btn-sm disabled">Trang @Model.Page</span>
                    @if (Model.HasNext)
                    {
                        <a asp-action="Search" asp-route-keyword="@Model.Keyword"
                           asp-route-page="@(Model.Page + 1)"
                           class="btn btn-outline-secondary btn-sm">
                            Sau <i class="bi bi-chevron-right"></i>
                        </a>
                    }
                </div>
            }
        }
    }
</div>