@model LocketSystem.Web.Models.CreatePostViewModel
@{
    ViewData["Title"] = "Đăng bài mới"; Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-6">
        <div class="card border-0 shadow-sm" style="border-radius:1.25rem">
            <div class="card-body p-4">
                <h5 class="fw-700 mb-1"><i class="bi bi-image me-2"></i>Đăng bài mới</h5>
                <p class="text-muted small mb-4">Chia sẻ khoảnh khắc với bạn bè của bạn.</p>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Caption" class="form-label fw-600 small">Caption</label>
                        <textarea asp-for="Caption" class="form-control" rows="4"
                                  placeholder="Bạn đang nghĩ gì?..."></textarea>
                        <span asp-validation-for="Caption" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageFile" class="form-label fw-600 small">Chọn ảnh từ máy</label>
                        <input type="file" asp-for="ImageFile" class="form-control"
                               accept="image/png, image/jpeg, image/gif, image/webp"
                               onchange="previewFromFile(this)" />
                        <div class="form-text">Hỗ trợ JPG, PNG, GIF, WEBP — tối đa 10MB.</div>
                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="text-center text-muted small mb-2">— hoặc —</div>
                        <label asp-for="ImageUrl" class="form-label fw-600 small">Dán URL ảnh có sẵn trên mạng</label>
                        <input asp-for="ImageUrl" class="form-control"
                               placeholder="https://example.com/anh.jpg"
                               oninput="previewFromUrl(this.value)" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        <div id="both-selected-warning" class="form-text text-warning d-none">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Bạn đã chọn cả file và URL — hệ thống sẽ ưu tiên dùng file ảnh đã chọn từ máy.
                        </div>
                    </div>

                    <div id="img-preview" class="mb-3 d-none">
                        <img id="preview-img" src="" alt="preview"
                             class="img-fluid rounded-3 w-100"
                             style="max-height:300px;object-fit:cover"
                             onerror="document.getElementById('img-preview').classList.add('d-none')" />
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-orange fw-600 flex-grow-1">
                            <i class="bi bi-send me-1"></i>Đăng bài
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ============================================================
        // Xem trước ảnh — CHỈ lo việc preview, KHÔNG xóa input còn lại.
        //
        // Lý do: input type="file" không thể được JS gán lại giá trị
        // sau khi bị clear (value = ''). Bản cũ từng xóa chéo 2 input
        // mỗi khi người dùng gõ/chọn cái còn lại, khiến nếu ai đó
        // chọn file rồi lỡ tay gõ thử vào ô URL rồi xóa đi, file đã
        // chọn sẽ bị mất vĩnh viễn mà không thể chọn lại bằng JS —
        // dẫn đến bài đăng bị thiếu ảnh dù caption vẫn hợp lệ.
        //
        // Server (PostsController.Create) đã tự ưu tiên ImageFile hơn
        // ImageUrl khi cả hai đều có giá trị, nên client không cần
        // và không nên tự ý xóa dữ liệu người dùng đã nhập.
        // ============================================================

        function getFileInput() {
            return document.querySelector('input[name="ImageFile"]');
        }
        function getUrlInput() {
            return document.querySelector('input[name="ImageUrl"]');
        }

        function previewFromFile(input) {
            const wrap = document.getElementById('img-preview');
            const img = document.getElementById('preview-img');
            const file = input.files && input.files[0];

            if (!file) {
                // Nếu không còn file nào, chỉ ẩn preview khi URL cũng trống
                if (!getUrlInput().value.trim()) {
                    wrap.classList.add('d-none');
                }
                updateBothSelectedWarning();
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                img.src = e.target.result;
                wrap.classList.remove('d-none');
            };
            reader.readAsDataURL(file);

            updateBothSelectedWarning();
        }

        function previewFromUrl(url) {
            const wrap = document.getElementById('img-preview');
            const img = document.getElementById('preview-img');
            const fileInput = getFileInput();

            if (url && url.startsWith('http')) {
                // Nếu chưa có file nào được chọn, hiển thị preview theo URL
                if (!fileInput.files.length) {
                    img.src = url;
                    wrap.classList.remove('d-none');
                }
            } else if (!fileInput.files.length) {
                wrap.classList.add('d-none');
            }

            updateBothSelectedWarning();
        }

        // Hiện cảnh báo nhẹ nếu người dùng đang có cả file lẫn URL
        // để tránh nhầm lẫn ảnh nào sẽ thực sự được đăng.
        function updateBothSelectedWarning() {
            const warning = document.getElementById('both-selected-warning');
            const hasFile = getFileInput().files.length > 0;
            const hasUrl = getUrlInput().value.trim() !== '';

            warning.classList.toggle('d-none', !(hasFile && hasUrl));
        }
    </script>
}