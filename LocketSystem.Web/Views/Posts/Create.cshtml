@model LocketSystem.Web.Models.CreatePostViewModel
@{
    ViewData["Title"] = "Đăng bài mới"; Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-6">
        <div class="card border-0 shadow-sm" style="border-radius:1.25rem">
            <div class="card-body p-4">
                <h5 class="fw-700 mb-1"><i class="bi bi-image me-2"></i>Đăng bài mới</h5>
                <p class="text-muted small mb-4">Chia sẻ khoảnh khắc với bạn bè của bạn.</p>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Caption" class="form-label fw-600 small">Caption</label>
                        <textarea asp-for="Caption" class="form-control" rows="4"
                                  placeholder="Bạn đang nghĩ gì?..."></textarea>
                        <span asp-validation-for="Caption" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageFile" class="form-label fw-600 small">Chọn ảnh từ máy</label>
                        <input type="file" asp-for="ImageFile" class="form-control"
                               accept="image/png, image/jpeg, image/gif, image/webp"
                               onchange="previewFromFile(this)" />
                        <div class="form-text">Hỗ trợ JPG, PNG, GIF, WEBP — tối đa 10MB.</div>
                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="text-center text-muted small mb-2">— hoặc —</div>
                        <label asp-for="ImageUrl" class="form-label fw-600 small">Dán URL ảnh có sẵn trên mạng</label>
                        <input asp-for="ImageUrl" class="form-control"
                               placeholder="https://example.com/anh.jpg"
                               oninput="previewFromUrl(this.value)" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div id="img-preview" class="mb-3 d-none">
                        <img id="preview-img" src="" alt="preview"
                             class="img-fluid rounded-3 w-100"
                             style="max-height:300px;object-fit:cover"
                             onerror="document.getElementById('img-preview').classList.add('d-none')" />
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-orange fw-600 flex-grow-1">
                            <i class="bi bi-send me-1"></i>Đăng bài
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Huỷ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Xem trước ảnh CHỌN TỪ MÁY bằng FileReader (chỉ để xem trước tại chỗ,
        // KHÔNG phải là URL sẽ lưu vào DB — server sẽ tự lưu file thật khi submit).
        function previewFromFile(input) {
            const wrap = document.getElementById('img-preview');
            const img = document.getElementById('preview-img');
            const file = input.files && input.files[0];

            if (!file) { wrap.classList.add('d-none'); return; }

            const reader = new FileReader();
            reader.onload = function (e) {
                img.src = e.target.result;
                wrap.classList.remove('d-none');
            };
            reader.readAsDataURL(file);

            // Nếu đã chọn file thì xoá URL nhập tay để tránh xung đột
            const urlInput = document.querySelector('input[name="ImageUrl"]');
            if (urlInput) urlInput.value = '';
        }

        // Xem trước khi dán URL ảnh có sẵn
        function previewFromUrl(url) {
            const wrap = document.getElementById('img-preview');
            const img = document.getElementById('preview-img');

            if (url && url.startsWith('http')) {
                img.src = url;
                wrap.classList.remove('d-none');

                // Nếu đã nhập URL thì bỏ file đã chọn để tránh xung đột
                const fileInput = document.querySelector('input[name="ImageFile"]');
                if (fileInput) fileInput.value = '';
            } else {
                wrap.classList.add('d-none');
            }
        }
    </script>
}
