@model LocketSystem.Web.Models.PostDetailViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Chi tiết bài viết";
    Layout = "_Layout";
    var myId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0");
    var post = Model.Post;
}

<div class="container" style="max-width:700px">

    <a asp-action="Index" class="btn btn-sm btn-light mb-3">
        <i class="bi bi-arrow-left me-1"></i>Quay lại Feed
    </a>

    <div class="card card-post mb-3">
        <div class="card-body pb-2 d-flex align-items-center gap-3">
            <a asp-controller="Users" asp-action="Profile" asp-route-id="@post.UserId" class="text-decoration-none">
                <span class="avatar">@post.Username.Substring(0, 1).ToUpper()</span>
            </a>
            <div class="flex-grow-1">
                <a asp-controller="Users" asp-action="Profile" asp-route-id="@post.UserId"
                   class="fw-700 text-dark text-decoration-none">@post.Username</a>
                <div class="text-muted" style="font-size:.78rem">
                    <i class="bi bi-clock me-1"></i>@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>
            @if (post.UserId == myId)
            {
                <div class="dropdown">
                    <button class="btn btn-sm btn-light border-0" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius:.6rem">
                        <li>
                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Xác nhận xóa bài viết này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@post.PostId" />
                                <button class="dropdown-item text-danger small">
                                    <i class="bi bi-trash me-2"></i>Xóa bài
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(post.Caption))
        {
            <div class="px-4 pb-2" style="font-size:1rem">@post.Caption</div>
        }

        @if (!string.IsNullOrWhiteSpace(post.ImageUrl))
        {
            <img src="@post.ImageUrl.ToWebPath()" class="post-image" alt="post"
                 onerror="this.src='/img/no-image.png'" />
        }

        <div class="card-body pt-2 pb-1">
            <div class="d-flex align-items-center gap-3">
                @if (post.LikedByMe)
                {
                    <form asp-action="Unlike" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@post.PostId" />
                        <input type="hidden" name="ret" value="Detail" />
                        <button class="btn-like liked fw-600">
                            <i class="bi bi-heart-fill"></i> @post.LikeCount lượt thích
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="Like" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@post.PostId" />
                        <input type="hidden" name="ret" value="Detail" />
                        <button class="btn-like fw-600">
                            <i class="bi bi-heart"></i> @post.LikeCount lượt thích
                        </button>
                    </form>
                }
                <span class="text-muted small">
                    <i class="bi bi-chat me-1"></i>@post.CommentCount bình luận
                </span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
        <div class="card-body">
            <h6 class="fw-700 mb-3">Bình luận (@Model.Comments.Count)</h6>

            @foreach (var c in Model.Comments)
            {
                <div class="d-flex gap-2 mb-3 align-items-start" id="comment-@c.CommentId">
                    <span class="avatar" style="width:32px;height:32px;font-size:.75rem">
                        @c.Username.Substring(0, 1).ToUpper()
                    </span>
                    <div class="flex-grow-1">
                        <div class="bg-light rounded-3 px-3 py-2" style="font-size:.92rem">
                            <span class="fw-700 me-1">@c.Username</span>
                            <span id="comment-text-@c.CommentId">@c.Content</span>
                            <form asp-action="EditComment" method="post" id="edit-form-@c.CommentId" class="d-none mt-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="commentId" value="@c.CommentId" />
                                <input type="hidden" name="postId" value="@post.PostId" />
                                <div class="input-group input-group-sm">
                                    <input type="text" name="newContent" class="form-control"
                                           value="@c.Content" id="edit-input-@c.CommentId" />
                                    <button class="btn btn-orange btn-sm" type="submit">Lưu</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="cancelEdit(@c.CommentId)">
                                        Huỷ
                                    </button>
                                </div>
                            </form>
                        </div>
                        <div class="text-muted mt-1" style="font-size:.75rem">
                            @c.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            @if (c.UserId == myId)
                            {
                                <button class="btn btn-link btn-sm p-0 ms-2 text-muted"
                                        style="font-size:.75rem"
                                        onclick="startEdit(@c.CommentId)">
                                    Sửa
                                </button>
                                <span class="mx-1">·</span>
                                <form asp-action="DeleteComment" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa bình luận này?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.CommentId" />
                                    <input type="hidden" name="postId" value="@post.PostId" />
                                    <button class="btn btn-link btn-sm p-0 text-danger" style="font-size:.75rem">Xóa</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Comments.Any())
            {
                <p class="text-muted small text-center py-2">Chưa có bình luận. Hãy là người đầu tiên! 💬</p>
            }

            <form asp-action="AddComment" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@post.PostId" />
                <div class="d-flex gap-2">
                    <span class="avatar" style="width:32px;height:32px;font-size:.75rem">
                        @User.Identity!.Name?.Substring(0, 1).ToUpper()
                    </span>
                    <div class="input-group">
                        <input type="text" name="content" class="form-control form-control-sm"
                               placeholder="Viết bình luận..." maxlength="1000" required />
                        <button class="btn btn-orange btn-sm" type="submit">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>
            </form>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        function startEdit(id) {
            document.getElementById('comment-text-' + id).classList.add('d-none');
            document.getElementById('edit-form-' + id).classList.remove('d-none');
            document.getElementById('edit-input-' + id).focus();
        }
        function cancelEdit(id) {
            document.getElementById('comment-text-' + id).classList.remove('d-none');
            document.getElementById('edit-form-' + id).classList.add('d-none');
        }
    </script>
}